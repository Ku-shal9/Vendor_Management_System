{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://vendor-management-system-5di6.onrender.com/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://vendor-management-system-5di6.onrender.com/uploads/:path*"
        },
        {
            "source": "/((?!api|uploads).*LayoutDashboard|.*)",
            "destination": "/index.html"
        }
    ]
}